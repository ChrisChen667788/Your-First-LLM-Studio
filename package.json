{
  "name": "local-agent-lab",
  "version": "1.1.0-rc.2",
  "private": true,
  "description": "First LLM Studio: local-first LLM workbench for Apple Silicon with MLX runtimes, Compare Lab, benchmark ops, and remote model comparisons.",
  "license": "MIT",
  "homepage": "https://github.com/ChrisChen667788/Your-First-LLM-Studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisChen667788/Your-First-LLM-Studio.git"
  },
  "bugs": {
    "url": "https://github.com/ChrisChen667788/Your-First-LLM-Studio/issues"
  },
  "keywords": [
    "agent",
    "benchmark",
    "mlx",
    "apple-silicon",
    "nextjs",
    "llm",
    "qwen",
    "coding-agent",
    "observability"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "./scripts/run-next.sh dev 3011",
    "build": "./scripts/run-next.sh build",
    "start": "./scripts/run-next.sh start 3011",
    "lint": "./scripts/run-lint.sh",
    "typecheck": "./scripts/run-typecheck.sh full",
    "typecheck:partitions": "./scripts/run-typecheck.sh partitions",
    "typecheck:changed": "./scripts/run-typecheck.sh changed",
    "smoke:routes": "bash ./scripts/route-smoke.sh",
    "smoke:screenshots": "./scripts/screenshot-smoke.sh",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "screenshots:release": "node scripts/capture-release-demo-screenshots.mjs",
    "validate:screenshots": "node scripts/validate-release-screenshots.mjs",
    "preflight:aws-production-promotion": "node scripts/preflight-aws-production-promotion.mjs",
    "preflight:release-security": "node scripts/release-security-preflight.mjs",
    "rehearse:post-v1-foundations": "node scripts/rehearse-post-v1-foundations.mjs",
    "rehearse:postgres-rls": "node scripts/rehearse-postgres-rls.mjs",
    "rehearse:post-v1-closure": "node scripts/rehearse-post-v1-closure.mjs",
    "rehearse:post-v1-hardening": "node scripts/rehearse-post-v1-hardening.mjs",
    "rehearse:post-v1-acceptance": "node scripts/rehearse-post-v1-acceptance.mjs",
    "rehearse:post-v1-lifecycle": "node scripts/rehearse-post-v1-lifecycle.mjs",
    "build:desktop-rc": "node scripts/build-desktop-rc.mjs",
    "verify:desktop-rc": "node scripts/verify-desktop-dmg.mjs",
    "rehearse:v1.1-desktop": "node scripts/rehearse-v110-desktop-release.mjs",
    "import:desktop-acceptance": "node scripts/import-desktop-acceptance.mjs",
    "rehearse:desktop-external-acceptance": "node scripts/rehearse-desktop-external-acceptance.mjs",
    "typecheck:validate": "./scripts/run-typecheck.sh validate",
    "typecheck:changed:dry": "TYPECHECK_DRY_RUN=1 ./scripts/run-typecheck.sh changed",
    "typecheck:core": "./scripts/run-typecheck.sh core",
    "typecheck:core:shared": "./scripts/run-typecheck.sh core-shared",
    "typecheck:core:i18n": "./scripts/run-typecheck.sh core-i18n",
    "typecheck:core:demo-data": "./scripts/run-typecheck.sh core-demo-data",
    "typecheck:core:agent": "./scripts/run-typecheck.sh core-agent",
    "typecheck:core:finetune": "./scripts/run-typecheck.sh core-finetune",
    "typecheck:core:community": "./scripts/run-typecheck.sh core-community",
    "typecheck:core:scripts": "./scripts/run-typecheck.sh core-scripts",
    "typecheck:profile:core": "./scripts/run-typecheck.sh profile core",
    "typecheck:agent": "./scripts/run-typecheck.sh agent",
    "typecheck:agent:api": "./scripts/run-typecheck.sh agent-api",
    "typecheck:agent:ui": "./scripts/run-typecheck.sh agent-ui",
    "typecheck:agent:full": "./scripts/run-typecheck.sh agent-full",
    "typecheck:admin": "./scripts/run-typecheck.sh admin",
    "typecheck:app": "./scripts/run-typecheck.sh app"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.18",
    "playwright": "^1.54.1",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.9",
    "typescript": "5.5.4"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
