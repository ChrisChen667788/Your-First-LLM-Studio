{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "scripts/**/*.ts",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules",
    "node_modules 2",
    ".venv",
    "data",
    "tmp",
    "dist",
    "output",
    ".codex-run",
    ".dataless-backups",
    ".git.dataless-backup-*",
    ".next",
    ".next-*",
    ".next.*",
    ".next-dev",
    ".next-local-dev",
    ".next-build",
    ".next.bak.*",
    ".next.empty.*"
  ]
}
